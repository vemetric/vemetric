{
  "name": "vemetric",
  "description": "Simple, yet powerful web- and product analytics.",
  "private": true,
  "author": "Vemetric <info@vemetric.com> (https://vemetric.com/)",
  "scripts": {
    "build": "turbo run build --filter=!./apps/dev-proxy",
    "dev": "turbo run dev --filter=!./apps/health-check",
    "lint": "turbo run lint",
    "tsc": "turbo run tsc",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:integration": "turbo run test:integration",
    "e2e": "turbo run e2e --filter=e2e",
    "e2e:ui": "turbo run e2e:ui --filter=e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "turbo": "turbo"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "turbo": "2.9.7"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.11"
}
