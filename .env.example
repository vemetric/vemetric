# Vemetric
VEMETRIC_TOKEN=PLACEHOLDER

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/vemetric?schema=public"

# ClickHouse Migrations
CH_MIGRATIONS_HOST=http://localhost:8123
CH_MIGRATIONS_USER=default
CH_MIGRATIONS_PASSWORD=password
CH_MIGRATIONS_DB=vemetric

CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DB=vemetric

# Redis
REDIS_URL=redis://localhost:6379

# Used for verifying email unsubscribe tokens
EMAIL_TOKEN_SECRET=its-a-secret

# Better Auth
BETTER_AUTH_SECRET=123456789
BETTER_AUTH_URL=https://app.vemetric.localhost:4050

# Paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET_KEY=

# Postmark
POSTMARK_SERVER_API_TOKEN=PLACEHOLDER
POSTMARK_TRANSACTIONAL_MESSAGE_STREAM_ID=outbound

# Bullboard
BULLBOARD_USERNAME=bullboard
BULLBOARD_PASSWORD=password
BULLMQ_JOB_DEBUG_LOGS=true 

# Local debugging: duplicate pino logs to a JSON-lines file.
# LOG_FILE=/absolute/path/to/vemetric-local.ndjson

# Memory Reports
# Disabled by default. Set to true to enable in production.
# MEMORY_REPORT_ENABLED=true
# MEMORY_REPORT_INTERVAL_MS=3600000
# MEMORY_REPORT_RSS_THRESHOLDS_MB=1024,1536,2048

# Avatar Storage (Optional - enables avatar uploads when configured)
# Works with any S3-compatible service (AWS S3, Cloudflare R2, MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AWS_S3_AVATARS_BUCKET=vemetric-avatars
# AWS_S3_AVATARS_REGION=auto
# AWS_S3_AVATARS_PUBLIC_URL=https://avatars.vemetric.com
# AWS_S3_AVATARS_KEY_PREFIX=avatars/  # Leave empty for dedicated subdomain (e.g., avatars.example.com)
